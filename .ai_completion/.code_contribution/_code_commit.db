  "range-cache-/Users/ju/icon-animation.html": "[{\"originRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":125,\"character\":7}},\"modifyRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":125,\"character\":7}},\"action\":\"None\",\"isLine\":false,\"originAcceptText\":\"<!DOCTYPE html>\\n<html lang=\\\"zh-CN\\\">\\n<head>\\n    <meta charset=\\\"UTF-8\\\">\\n    <meta name=\\\"viewport\\\" content=\\\"width=device-width, initial-scale=1.0\\\">\\n    <title>图标动效</title>\\n    <style>\\n        body {\\n            display: flex;\\n            justify-content: center;\\n            align-items: center;\\n            height: 100vh;\\n            margin: 0;\\n            background-color: #1a1a1a;\\n            font-family: Arial, sans-serif;\\n        }\\n        \\n        .icon-container {\\n            position: relative;\\n            width: 200px;\\n            height: 200px;\\n            cursor: pointer;\\n        }\\n        \\n        .icon-background {\\n            position: absolute;\\n            top: 0;\\n            left: 0;\\n            width: 100%;\\n            height: 100%;\\n            background: linear-gradient(135deg, #1a237e, #283593);\\n            border-radius: 40px;\\n            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.3);\\n            transition: all 0.3s ease;\\n        }\\n        \\n        .icon {\\n            position: absolute;\\n            top: 50%;\\n            left: 50%;\\n            transform: translate(-50%, -50%);\\n            width: 120px;\\n            height: 140px;\\n            transition: all 0.3s ease;\\n        }\\n        \\n        .icon-path {\\n            fill: url(#gradient);\\n            transition: all 0.3s ease;\\n        }\\n        \\n        .icon-stripe {\\n            fill: rgba(255, 255, 255, 0.15);\\n            transition: all 0.3s ease;\\n        }\\n        \\n        .icon-container:hover .icon-background {\\n            transform: scale(1.05);\\n            box-shadow: 0 12px 24px rgba(0, 0, 0, 0.4);\\n        }\\n        \\n        .icon-container:hover .icon {\\n            transform: translate(-50%, -50%) scale(1.1);\\n        }\\n        \\n        .icon-container:active .icon-background {\\n            transform: scale(0.95);\\n        }\\n        \\n        .icon-container:active .icon {\\n            transform: translate(-50%, -50%) scale(0.95);\\n        }\\n        \\n        @keyframes pulse {\\n            0% {\\n                box-shadow: 0 0 0 0 rgba(66, 165, 245, 0.4);\\n            }\\n            70% {\\n                box-shadow: 0 0 0 15px rgba(66, 165, 245, 0);\\n            }\\n            100% {\\n                box-shadow: 0 0 0 0 rgba(66, 165, 245, 0);\\n            }\\n        }\\n        \\n        .pulse-effect {\\n            animation: pulse 2s infinite;\\n        }\\n    </style>\\n</head>\\n<body>\\n    <div class=\\\"icon-container\\\">\\n        <div class=\\\"icon-background\\\"></div>\\n        <svg class=\\\"icon\\\" viewBox=\\\"0 0 100 120\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\">\\n            <defs>\\n                <linearGradient id=\\\"gradient\\\" x1=\\\"0%\\\" y1=\\\"0%\\\" x2=\\\"100%\\\" y2=\\\"100%\\\">\\n                    <stop offset=\\\"0%\\\" stop-color=\\\"#ffffff\\\"/>\\n                    <stop offset=\\\"100%\\\" stop-color=\\\"#2196f3\\\"/>\\n                </linearGradient>\\n            </defs>\\n            <!-- 主V形 -->\\n            <path class=\\\"icon-path\\\" d=\\\"M25 20 L50 80 L75 20 Z\\\"/>\\n            <!-- 条纹 -->\\n            <path class=\\\"icon-stripe\\\" d=\\\"M30 35 L45 65 L40 70 L25 40 Z\\\"/>\\n            <path class=\\\"icon-stripe\\\" d=\\\"M35 45 L50 75 L45 80 L30 50 Z\\\"/>\\n            <path class=\\\"icon-stripe\\\" d=\\\"M65 35 L50 65 L55 70 L70 40 Z\\\"/>\\n            <path class=\\\"icon-stripe\\\" d=\\\"M60 45 L45 75 L50 80 L65 50 Z\\\"/>\\n            <!-- 右侧小三角形 -->\\n            <path class=\\\"icon-path\\\" d=\\\"M65 35 L75 20 L80 45 L70 55 Z\\\"/>\\n        </svg>\\n    </div>\\n    \\n    <script>\\n        const iconContainer = document.querySelector('.icon-container');\\n        \\n        // 点击时添加脉冲效果\\n        iconContainer.addEventListener('click', function() {\\n            const background = this.querySelector('.icon-background');\\n            background.classList.add('pulse-effect');\\n            setTimeout(() => {\\n                background.classList.remove('pulse-effect');\\n            }, 2000);\\n        });\\n    </script>\\n</body>\\n</html>\",\"originTextLength\":3819,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1775101164158}]",
