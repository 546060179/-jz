<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="117dp"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Cover area -->
    <FrameLayout
        android:layout_width="117dp"
        android:layout_height="wrap_content">

        <FrameLayout
            android:layout_width="117dp"
            android:layout_height="156dp"
            android:background="@drawable/bg_book_card_cover"
            android:clipChildren="true">

            <ImageView
                android:id="@+id/coverImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="@null" />

            <!-- Play count badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="4dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:background="@drawable/bg_play_count">

                <ImageView
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:src="@drawable/icon_play"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/playCountText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textColor="@color/drama_fill_white"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>
        </FrameLayout>

        <!-- Badge (top-end) -->
        <FrameLayout
            android:id="@+id/badgeContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="4dp"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Info section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:textColor="@color/drama_text_blue"
            android:textSize="12sp"
            android:fontFamily="sans-serif-light"
            android:maxLines="2"
            android:ellipsize="end" />

        <LinearLayout
            android:id="@+id/genreContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp" />
    </LinearLayout>
</LinearLayout>
