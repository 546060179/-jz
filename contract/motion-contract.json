{
  "$comment": "跨端动效契约黄金值（单一事实源）。core / iOS / Android 的契约测试均断言各自实现与此文件一致，防止某端漂移。修改动效令牌时同步更新此文件。",
  "timings": { "t1": 100, "t2": 150, "t3": 300, "t4": 500, "t5": 700 },
  "distances": { "d1": 4, "d2": 8, "d3": 16, "d4": 32, "d5": 64 },
  "easings": {
    "productive": [0.2, 0, 0.38, 0.9],
    "expressive": [0.4, 0.14, 0.3, 1],
    "enter": [0, 0, 0.3, 1],
    "exit": [0.4, 0, 1, 1],
    "bounce": [0.34, 1.56, 0.64, 1]
  },
  "intentDefaults": {
    "enter": { "timing": "t3", "easing": "enter" },
    "exit": { "timing": "t2", "easing": "exit" },
    "focus": { "timing": "t2", "easing": "expressive" },
    "feedback": { "timing": "t1", "easing": "productive" },
    "delight": { "timing": "t4", "easing": "expressive" }
  },
  "springs": {
    "gentle": { "stiffness": 120, "damping": 14, "mass": 1 },
    "snappy": { "stiffness": 300, "damping": 20, "mass": 1 },
    "bouncy": { "stiffness": 200, "damping": 10, "mass": 1 },
    "slow": { "stiffness": 80, "damping": 12, "mass": 1.5 },
    "noWobble": { "stiffness": 170, "damping": 26, "mass": 1 }
  },
  "effectPresets": {
    "$comment": "blur-in 刻意从 0.6 透明度起步(而非 0)以区别于纯淡入；初始模糊 14px。五端同款。",
    "blurFadeIn": { "opacityFrom": 0.6, "opacityTo": 1, "blurFrom": 14, "blurTo": 0 }
  },
  "components": {
    "$comment": "业务组件默认参数（时长单位 ms）。三端默认值须与此一致。",
    "bubbleExpand": { "zeta": 0.5, "omega": 9.0, "expandDuration": 650, "textFadeDuration": 300 },
    "continueWatching": { "slideUpDuration": 450, "collapseDelay": 3000, "fadeOutDuration": 300, "shrinkDuration": 400, "morphDuration": 550 }
  }
