python3 << 'PYEOF'\
with open('continue-watching-widget/native/ios/BubbleExpandView.swift', 'r') as f:\
    content = f.read()\
\
changes = 0\
\
# Fix 1: base64 decoding with ignoreUnknownCharacters\
old1 = 'Data(base64Encoded: Self.bubbleImageBase64)'\
new1 = 'Data(base64Encoded: Self.bubbleImageBase64, options: .ignoreUnknownCharacters)'\
if old1 in content:\
    content = content.replace(old1, new1)\
    changes += 1\
    print("Fix 1: Added .ignoreUnknownCharacters")\
else:\
    print("Fix 1: Already applied or not found")\
\
# Fix 2: Add layoutIfNeeded + bounds guard in play()\
old2 = """        phase = .expanding\
        alpha = 1\
        textMask.alpha = 1\
        applyScaleFromRight(0.001)\
        phaseStartTime = 0"""\
\
new2 = """        phase = .expanding\
        alpha = 1\
        textMask.alpha = 1\
        // ńāü«õ┐āĮ Auto Layout ÕĘ▓Ķ«āüń«āĘÕ«ā¼ bounds\
        setNeedsLayout()\
        layoutIfNeeded()\
        // Õ”éµāŠā╝ bounds Ķ┐āĖµāĖ» 0’╝ā¼Õ╗ČĶ┐ā┐ķā¦āŁĶ»āĄ\
        guard bounds.width > 0 else {\
            phase = .idle\
            DispatchQueue.main.async { [weak self] in self?.play() }\
            return\
        }\
        applyScaleFromRight(0.001)\
        phaseStartTime = 0"""\
\
if 'guard bounds.width > 0' not in content:\
    content = content.replace(old2, new2)\
    changes += 1\
    print("Fix 2: Added layoutIfNeeded + bounds guard")\
else:\
    print("Fix 2: Already applied")\
\
# Fix 3: imageView contentMode should be scaleToFill for pixel-perfect\
old3 = 'imageView.contentMode = .scaleAspectFit'\
new3 = 'imageView.contentMode = .scaleToFill'\
if old3 in content:\
    content = content.replace(old3, new3)\
    changes += 1\
    print("Fix 3: Changed contentMode to scaleToFill")\
\
with open('continue-watching-widget/native/ios/BubbleExpandView.swift', 'w') as f:\
    f.write(content)\
print(f"Total changes: {changes}")\
PYEOF
