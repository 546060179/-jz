python3 -c "\
b64 = open('/tmp/bubble_b64.txt').read().strip()\
\
# Read the Swift file up to the base64 marker\
with open('continue-watching-widget/native/ios/BubbleExpandView.swift', 'r') as f:\
    lines = f.readlines()\
\
# Find the marker line\
marker_idx = None\
for i, line in enumerate(lines):\
    if 'bubbleImageBase64' in line:\
        marker_idx = i\
        break\
\
# Keep everything before the marker, rewrite from there\
header = ''.join(lines[:marker_idx])\
\
result = header\
result += '    private static let bubbleImageBase64: String = \"\"\"\n'\
# Split base64 into 76-char lines (standard)\
for i in range(0, len(b64), 76):\
    result += '    ' + b64[i:i+76] + '\n'\
result += '    \"\"\"\n'\
result += '}\n'\
\
with open('continue-watching-widget/native/ios/BubbleExpandView.swift', 'w') as f:\
    f.write(result)\
print('Done')\
"
