python3 << 'PYEOF'\
with open('continue-watching-widget/native/ios/BubbleExpandView.swift', 'r') as f:\
    content = f.read()\
\
# 1. Fix base64 decoding: add ignoreUnknownCharacters option to handle whitespace\
content = content.replace(\
    'Data(base64Encoded: Self.bubbleImageBase64)',\
    'Data(base64Encoded: Self.bubbleImageBase64, options: .ignoreUnknownCharacters)'\
)\
\
# 2. Add a guard in play() for zero bounds\
old_play = """// ńāü«õ┐āĮÕĖāŻÕ▒ĆÕĘ▓Õ«ā¼µā©ā░’╝ā¼bounds.width µā╝ā®ÕĆ╝\
        layoutIfNeeded()\
        applyScaleFromRight(0.001)"""\
\
new_play = """// ńāü«õ┐āĮÕĖāŻÕ▒ĆÕĘ▓Õ«ā¼µā©ā░’╝ā¼bounds.width µā╝ā®ÕĆ╝\
        layoutIfNeeded()\
        guard bounds.width > 0 else {\
            // ń║”µāĮā┐Ķ┐āĖµ▓āüńā┤ā┐µāĄā©’╝ā¼Õ╗ČĶ┐ā┐Õā©░õĖā½õĖĆÕĖ¦ķā¦āŁĶ»āĄ\
            DispatchQueue.main.async { [weak self] in\
                self?.phase = .idle\
                self?.play()\
            }\
            return\
        }\
        applyScaleFromRight(0.001)"""\
\
content = content.replace(old_play, new_play)\
\
with open('continue-watching-widget/native/ios/BubbleExpandView.swift', 'w') as f:\
    f.write(content)\
print("Done")\
PYEOF
