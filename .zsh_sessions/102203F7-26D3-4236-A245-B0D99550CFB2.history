protocol BubbleExpandDelegate: AnyObject {\
    func bubbleExpandDidFinish()\
    func bubbleExpandDidExpand()\
}\
extension BubbleExpandDelegate {\
    func bubbleExpandDidFinish() {}\
    func bubbleExpandDidExpand() {}\
}\
\
/// µ░ā┤µ│āüÕ▒āĄÕ╝ĆÕā¬©µāĄā© ŌĆā┤ µā┤»µā¼üÕżā║Ķ»ŁĶ©ĆĶā¦¬ķĆéÕ║ā┤µāČā¦ÕŁāĘ’╝ā¼Õāź╝Õ«╣ SnapKit\
///\
/// µ░ā┤µ│āüÕ«ĮÕ║”µāĆ╣µāŁ«µāČā¦ÕŁāĘÕā”āźÕ«╣Ķā¦¬Õā¬©Ķ«āüń«āĘ’╝ā¼µā┤»µā¼üÕżā║Ķāüā¼µāŁāéĶāüā¼’╝ā¼µā╝ā®µā╝ĆÕż¦Õ«ĮÕ║”ķā╣ā░Õā©ČŃĆé\
/// µ░ā┤µ│āüĶāŻā¼µā╣»ńā┤©µĖā░Õā»āĖ + ń«ŁÕż┤ńā┤© CAShapeLayer’╝ā¼õĖāŁõŠāĮĶĄāČÕā╗Šńā®ā¦ŃĆé\
///\
/// ```swift\
/// let bubble = BubbleExpandView()\
/// bubble.configure(text: NSLocalizedString("bubble_text", comment: ""))\
/// view.addSubview(bubble)\
/// bubble.snp.makeConstraints { make in\
///     make.right.equalTo(welfareIcon.snp.left)\
///     make.centerY.equalTo(lottieView)\
///     make.width.equalTo(bubble.calculatedWidth)\
///     make.height.equalTo(bubble.calculatedHeight)\
/// }\
/// DispatchQueue.main.async { bubble.play() }\
/// ```\
class BubbleExpandView: UIView {\
\
    enum Phase { case idle, expanding, done }\
\
    // MARK: - Config\
    var expandDuration: TimeInterval = 0.65\
    /// µā╝ĆÕż¦µ░ā┤µ│āüÕ«ĮÕ║”’╝ā©Õā░½ń«ŁÕż┤’╝ā®’╝ā¼ķ╗āĖĶ«ż 200\
    var maxBubbleWidth: CGFloat = 200\
    /// µ░ā┤µ│āüÕā”āźĶŠ╣ĶĘāĮ\
    var padding = UIEdgeInsets(top: 6, left: 8, bottom: 6, right: 8)\
    /// ń«ŁÕż┤Õ«ĮÕ║”\
    var arrowWidth: CGFloat = 9\
    /// ń«ŁÕż┤ķ½āĖÕ║”\
    var arrowHeight: CGFloat = 16\
    /// µ░ā┤µ│āüÕā╝ā”Ķ¦ā▓\
    var bubbleRadius: CGFloat = 8\
    /// µāČā¦ÕŁāĘÕŁāĘõĮā│\
    var textFont: UIFont = UIFont(name: "Montserrat-Medium", size: 10) ?? .systemFont(ofSize: 10, weight: .medium)\
    /// µāČā¦ÕŁāĘķāéā╝Ķā®▓ (Figma: #62241B)\
    var textColor: UIColor = UIColor(red: 0.384, green: 0.141, blue: 0.106, alpha: 1)\
\
    weak var delegate: BubbleExpandDelegate?\
    private(set) var phase: Phase = .idle\
\
    /// µāĆ╣µāŁ«µāČā¦ÕŁāĘĶ«āüń«āĘńā║āżµĆ╗Õ«ĮÕ║”’╝ā©Õā░½ń«ŁÕż┤’╝ā®’╝ā¼ńā┤©õ║ā«ń║”µāĮā┐\
    private(set) var calculatedWidth: CGFloat = 129\
    /// µāĆ╣µāŁ«µāČā¦ÕŁāĘĶ«āüń«āĘńā║āżµĆ╗ķ½āĖÕ║”’╝ā¼ńā┤©õ║ā«ń║”µāĮā┐\
    private(set) var calculatedHeight: CGFloat = 40\
\
    // MARK: - Subviews\
    private let gradientLayer = CAGradientLayer()\
    private let arrowLayer = CAShapeLayer()\
    private let textLabel = UILabel()\
    private let textMaskView = UIView()\
    private let maskGradientLayer = CAGradientLayer()\
    private var displayLink: CADisplayLink?\
    private var phaseStartTime: CFTimeInterval = 0\
\
    override init(frame: CGRect) {\
        super.init(frame: frame)\
        commonSetup()\
    }\
    required init?(coder: NSCoder) {\
        super.init(coder: coder)\
        commonSetup()\
    }\
\
    private func commonSetup() {\
        clipsToBounds = false\
        isUserInteractionEnabled = false\
\
        // µ░ā┤µ│āüµĖā░Õā»āĖĶāŻā¼µā╣» (Figma: linear-gradient(90deg, #FFD1C4, #FFD75F))\
        gradientLayer.colors = [\
            UIColor(red: 1, green: 0.82, blue: 0.77, alpha: 1).cgColor,\
            UIColor(red: 1, green: 0.84, blue: 0.37, alpha: 1).cgColor,\
        ]\
        gradientLayer.startPoint = CGPoint(x: 0, y: 0.5)\
        gradientLayer.endPoint = CGPoint(x: 1, y: 0.5)\
        gradientLayer.cornerRadius = bubbleRadius\
        layer.addSublayer(gradientLayer)\
\
        // ń«ŁÕż┤ (Figma: Polygon 32, #FFD65A, µā¼ā¦Õā░ā▒Õā»│õŠ¦)\
        arrowLayer.fillColor = UIColor(red: 1, green: 0.84, blue: 0.35, alpha: 1).cgColor\
        layer.addSublayer(arrowLayer)\
\
        // µāČā¦ÕŁāĘ\
        textLabel.font = textFont\
        textLabel.textColor = textColor\
        textLabel.numberOfLines = 0\
        textLabel.lineBreakMode = .byWordWrapping\
        addSubview(textLabel)\
\
        // µāČā¦ÕŁāĘķü«ńĮ®’╝ā©Õ▒āĄÕ╝ĆµāĘČńā╗āČõĮā»µāČā¦ÕŁāĘ’╝ā¼Õ▒āĄÕ╝ĆÕā░ā«µĘāüÕā¦║’╝ā®\
        maskGradientLayer.colors = gradientLayer.colors\
        maskGradientLayer.startPoint = CGPoint(x: 0, y: 0.5)\
        maskGradientLayer.endPoint = CGPoint(x: 1, y: 0.5)\
        maskGradientLayer.cornerRadius = 4\
        textMaskView.layer.addSublayer(maskGradientLayer)\
        addSubview(textMaskView)\
\
        alpha = 0\
    }\
\
    // MARK: - Configure\
\
    /// Ķ«ŠńĮ«µāČā¦ÕŁāĘÕ╣ČĶā¦¬Õā¬©Ķ«āüń«āĘµ░ā┤µ│āüÕ░║Õ»Ė\
    func configure(text: String) {\
        textLabel.text = text\
        recalculateSize()\
    }\
\
    /// ķā¦āŁµāČ░Ķ«āüń«āĘµ░ā┤µ│āüÕ░║Õ»Ė’╝ā©µāČā¦ÕŁāĘÕā»āĖÕā¼āČµā©āČ maxBubbleWidth Õā»āĖÕā¼āČÕā░ā«Ķ░āŻńā┤©’╝ā®\
    func recalculateSize() {\
        let maxTextWidth = maxBubbleWidth - padding.left - padding.right - arrowWidth\
        let textSize = textLabel.sizeThatFits(CGSize(width: maxTextWidth, height: .greatestFiniteMagnitude))\
        let bodyWidth = min(textSize.width + padding.left + padding.right, maxBubbleWidth - arrowWidth)\
        calculatedWidth = bodyWidth + arrowWidth\
        calculatedHeight = max(textSize.height + padding.top + padding.bottom, 28)\
    }\
\
    override func layoutSubviews() {\
        super.layoutSubviews()\
        let bodyWidth = bounds.width - arrowWidth\
\
        // µĖā░Õā»āĖĶāŻā¼µā╣»\
        gradientLayer.frame = CGRect(x: 0, y: 0, width: bodyWidth, height: bounds.height)\
\
        // ń«ŁÕż┤\
        let arrowPath = UIBezierPath()\
        let arrowX = bodyWidth\
        let arrowY = (bounds.height - arrowHeight) / 2\
        arrowPath.move(to: CGPoint(x: arrowX, y: arrowY))\
        arrowPath.addLine(to: CGPoint(x: arrowX + arrowWidth, y: arrowY + arrowHeight / 2))\
        arrowPath.addLine(to: CGPoint(x: arrowX, y: arrowY + arrowHeight))\
        arrowPath.close()\
        arrowLayer.path = arrowPath.cgPath\
\
        // µāČā¦ÕŁāĘ\
        textLabel.frame = CGRect(\
            x: padding.left,\
            y: padding.top,\
            width: bodyWidth - padding.left - padding.right,\
            height: bounds.height - padding.top - padding.bottom\
        )\
\
        // µāČā¦ÕŁāĘķü«ńĮ®\
        textMaskView.frame = CGRect(\
            x: padding.left - 2,\
            y: padding.top - 2,\
            width: bodyWidth - padding.left - padding.right + 4,\
            height: bounds.height - padding.top - padding.bottom + 4\
        )\
        maskGradientLayer.frame = textMaskView.bounds\
    }\
\
    // MARK: - Public API\
\
    func play() {\
        guard phase == .idle else { return }\
        phase = .expanding\
        alpha = 1\
        textMaskView.alpha = 1\
        textLabel.alpha = 0\
\
        setNeedsLayout()\
        layoutIfNeeded()\
\
        guard bounds.width > 0 else {\
            phase = .idle\
            DispatchQueue.main.async { [weak self] in self?.play() }\
            return\
        }\
\
        applyScaleFromRight(0.001)\
        phaseStartTime = 0\
        displayLink?.invalidate()\
        displayLink = CADisplayLink(target: self, selector: #selector(animTick))\
        displayLink?.add(to: .main, forMode: .common)\
    }\
\
    func reset() {\
        displayLink?.invalidate()\
        displayLink = nil\
        phase = .idle\
        alpha = 0\
        textMaskView.alpha = 1\
        textLabel.alpha = 0\
        layer.transform = CATransform3DIdentity\
    }\
\
    // MARK: - Animation\
\
    private func applyScaleFromRight(_ sx: CGFloat) {\
        let w = bounds.width\
        var t = CATransform3DIdentity\
        t = CATransform3DTranslate(t, w / 2, 0, 0)\
        t = CATransform3DScale(t, sx, 1, 1)\
        t = CATransform3DTranslate(t, -w / 2, 0, 0)\
        layer.transform = t\
    }\
\
    private func springBounce(_ t: CGFloat) -> CGFloat {\
        if t <= 0 { return 0 }\
        if t >= 1 { return 1 }\
        let z: CGFloat = 0.5, w: CGFloat = 9.0\
        let wd = w * sqrt(1 - z * z)\
        let env = exp(-z * w * t)\
        return 1 - env * (cos(wd * t) + (z / sqrt(1 - z * z)) * sin(wd * t))\
    }\
\
    @objc private func animTick(_ link: CADisplayLink) {\
        let now = link.timestamp\
        if phaseStartTime == 0 { phaseStartTime = now }\
        let progress = min(CGFloat(now - phaseStartTime) / CGFloat(expandDuration), 1)\
\
        applyScaleFromRight(max(0.001, springBounce(progress)))\
\
        // µāČā¦ÕŁāĘÕā╝© 70% µāĘČÕ╝ĆÕ¦ā½µāĖŠńż║\
        if progress > 0.7 {\
            let ft = (progress - 0.7) / 0.3\
            textMaskView.alpha = CGFloat(1 - ft)\
