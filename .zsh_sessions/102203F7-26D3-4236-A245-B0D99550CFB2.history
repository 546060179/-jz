<script>\
// Spring bounce (zeta=0.5, omega=9.0) ŌĆā┤ Õā▓ā¼ iOS õĖĆĶā¦┤\
function springBounce(t) {\
  if (t <= 0) return 0;\
  if (t >= 1) return 1;\
  var z = 0.5, w = 9.0;\
  var wd = w * Math.sqrt(1 - z * z);\
  var env = Math.exp(-z * w * t);\
  return 1 - env * (Math.cos(wd * t) + (z / Math.sqrt(1 - z * z)) * Math.sin(wd * t));\
}\
\
var bubble = document.getElementById('bubble');\
var text = document.getElementById('bubbleText');\
var EXPAND_MS = 650;\
var raf = 0;\
\
function play() {\
  reset();\
  bubble.style.opacity = '1';\
  var t0 = 0;\
  function tick(now) {\
    if (!t0) t0 = now;\
    var progress = Math.min((now - t0) / EXPAND_MS, 1);\
    var s = springBounce(progress);\
    bubble.style.transform = 'scaleX(' + Math.max(0.001, s) + ')';\
    // µāČā¦ÕŁāĘÕā╝© 70% µāĘČÕ╝ĆÕ¦ā½µĘāüÕāźź ŌĆā┤ Õā▓ā¼ iOS õĖĆĶā¦┤\
    if (progress > 0.7) {\
      var ft = (progress - 0.7) / 0.3;\
      text.style.opacity = String(ft);\
    }\
    if (progress >= 1) {\
      bubble.style.transform = 'scaleX(1)';\
      text.style.opacity = '1';\
      return;\
    }\
    raf = requestAnimationFrame(tick);\
  }\
  raf = requestAnimationFrame(tick);\
}\
\
function reset() {\
  cancelAnimationFrame(raf);\
  bubble.style.opacity = '0';\
  bubble.style.transform = 'scaleX(0)';\
  text.style.opacity = '0';\
}\
\
document.getElementById('btnPlay').addEventListener('click', play);\
document.getElementById('btnReset').addEventListener('click', reset);\
</script>\
</body>\
</html>'''\
\
with open('continue-watching-widget/preview-bubble-expand.html', 'w') as f:\
    f.write(html)\
print("Done")\
